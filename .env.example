# --- Trading mode: paper | live  (live pas na fase 2, zie PROJECTPLAN.md) ---
TRADING_MODE=paper

# --- Bitvavo (voor paper-modus volstaat een key ZONDER trade/withdraw rechten) ---
BITVAVO_API_KEY=
BITVAVO_API_SECRET=

# --- LLM providers (allemaal gratis tiers; minimaal 1 invullen, volgorde = fallback) ---
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# --- Telegram notificaties (optioneel) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Dashboard: token verplicht bij externe toegang ---
DASHBOARD_TOKEN=change-me

# --- Database ---
DATABASE_URL=sqlite:///data/tradebot.db
